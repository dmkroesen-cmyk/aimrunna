/* ═══════════════════════════════════════════════════════════════
   peak.athlete — Light Theme Design System
   Complete rewrite: April 2026
   ═══════════════════════════════════════════════════════════════ */

/* ───────────────────────────────────────────────────────────────
   1. DESIGN TOKENS
   ─────────────────────────────────────────────────────────────── */

:root {
  /* Backgrounds */
  --bg-primary: #FFFFFF;
  --bg-secondary: #F8F8FA;
  --bg-tertiary: #F0F0F3;

  /* Text */
  --text-primary: #1A1A1A;
  --text-secondary: #6B7280;
  --text-muted: #9CA3AF;
  --text-bright: #1A1A1A;
  --text-dim: #9CA3AF;
  --text-soft: #6B7280;
  --text-on-dark: #FFFFFF;

  /* Legacy compat tokens */
  --bg: #FFFFFF;
  --text: #1A1A1A;
  --muted: #6B7280;
  --muted-2: #9CA3AF;
  --line: rgba(0, 0, 0, 0.08);
  --line-soft: rgba(0, 0, 0, 0.04);
  --surface: rgba(0, 0, 0, 0.02);
  --surface-2: rgba(0, 0, 0, 0.035);
  --shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  --bg-base: #FFFFFF;
  --bg-card: #FFFFFF;
  --bg-raised: #F8F8FA;
  --bg-hover: #F0F0F3;

  /* Accent */
  --accent: #D4850F;
  --accent-fit: #D4850F;
  --accent-fatigue: #D4850F;
  --accent-fresh: #16A34A;
  --accent-ready: #D4850F;
  --accent-vo2: #D4850F;
  --accent-light: rgba(212, 133, 15, 0.08);
  --accent-medium: rgba(212, 133, 15, 0.15);
  --accent-strong: rgba(212, 133, 15, 0.25);
  --brand-gradient: linear-gradient(135deg, #D4850F 0%, #B8720D 100%);
  --brand-green: #16A34A;
  --brand-cyan: #D4850F;

  /* Status */
  --success: #16A34A;
  --success-light: rgba(22, 163, 74, 0.08);
  --warning: #F59E0B;
  --warning-light: rgba(245, 158, 11, 0.08);
  --danger: #DC2626;
  --danger-light: rgba(220, 38, 38, 0.08);
  --color-green: #16A34A;
  --color-amber: #F59E0B;
  --color-red: #DC2626;
  --color-danger: #DC2626;
  --color-success: #16A34A;
  --color-warning: #F59E0B;
  --color-info: #6B7280;

  /* Sport colors */
  --sport-run: #16A34A;
  --sport-trail: #15803D;
  --sport-bike: #3B82F6;
  --sport-mtb: #2563EB;
  --sport-swim: #06B6D4;
  --sport-hyrox: #F59E0B;
  --sport-gym: #EF4444;
  --sport-yoga: #A855F7;
  --sport-pilates: #C084FC;
  --sport-row: #3B82F6;
  --sport-walk: #9CA3AF;
  --sport-hike: #22C55E;
  --sport-ski: #6366F1;
  --sport-climb: #F97316;
  --sport-tri: #14B8A6;
  --sport-other: #6B7280;
  --sport-strength: #EF4444;

  /* Metric ring colors */
  --metric-readiness: #16A34A;
  --metric-strain: #3B82F6;
  --metric-recovery: #F59E0B;
  --metric-hrv: #A855F7;
  --metric-sleep: #6366F1;
  --metric-steps: #EF4444;
  --metric-fitness-age: #14B8A6;
  --metric-vo2max: #F97316;

  /* Intensity zones */
  --intensity-lit: #16A34A;
  --intensity-mit: #F59E0B;
  --intensity-hit: #EF4444;

  /* Borders */
  --border: rgba(0, 0, 0, 0.06);
  --border-strong: rgba(0, 0, 0, 0.10);
  --border-subtle: rgba(0, 0, 0, 0.04);
  --border-default: rgba(0, 0, 0, 0.08);
  --border-input: rgba(0, 0, 0, 0.12);
  --border-hover: rgba(0, 0, 0, 0.16);
  --border-focus: rgba(212, 133, 15, 0.4);

  /* Surfaces */
  --surface-dim: rgba(0, 0, 0, 0.01);
  --surface-3: rgba(0, 0, 0, 0.04);
  --surface-highlight: rgba(0, 0, 0, 0.05);
  --surface-subtle: rgba(0, 0, 0, 0.03);
  --overlay-soft: rgba(0, 0, 0, 0.25);
  --overlay-medium: rgba(0, 0, 0, 0.45);

  /* Shadows */
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.04);
  --shadow-md: 0 2px 8px rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 4px 16px rgba(0, 0, 0, 0.08);
  --shadow-xl: 0 8px 32px rgba(0, 0, 0, 0.10);
  --shadow-glow-green: 0 0 16px rgba(22, 163, 74, 0.10);
  --shadow-glow-cyan: 0 0 16px rgba(212, 133, 15, 0.10);

  /* Spacing */
  --space-xs: 4px;
  --space-sm: 8px;
  --space-md: 16px;
  --space-lg: 24px;
  --space-xl: 32px;
  --space-2xl: 48px;
  --space-3xl: 64px;
  --space-4xl: 96px;

  /* Typography */
  --font-main: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --font-xs: 10px;
  --font-sm: 12px;
  --font-base: 14px;
  --font-md: 14px;
  --font-lg: 16px;
  --font-xl: 18px;
  --font-2xl: 24px;
  --font-3xl: 32px;
  --font-4xl: 48px;
  --font-hero: 32px;
  --weight-regular: 400;
  --weight-medium: 500;
  --weight-semi: 600;
  --weight-bold: 700;
  --weight-black: 800;
  --lh-tight: 1.1;
  --lh-base: 1.5;
  --lh-loose: 1.6;

  /* Radii */
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 20px;
  --radius-full: 9999px;

  /* Transitions */
  --transition-smooth: cubic-bezier(0.16, 1, 0.3, 1);

  /* Layout */
  --container: 1240px;
  --global-header-mask-height: 56px;
  --global-header-line-top: 56px;

  /* Gradients */
  --gradient-avatar: linear-gradient(135deg, #D4850F, #B8720D);
  --gradient-modal: linear-gradient(135deg, #FFFFFF, #F8F8FA);

  /* Modal */
  --bg-modal: #FFFFFF;
  --bg-modal-card: #FFFFFF;

  /* Text compat */
  --text-tertiary: #9CA3AF;
}


/* ───────────────────────────────────────────────────────────────
   2. RESET & BASE
   ─────────────────────────────────────────────────────────────── */

*, *::before, *::after {
  box-sizing: border-box;
}

a {
  color: inherit;
  text-decoration: none;
}

html, body {
  margin: 0;
  min-height: 100%;
  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: var(--font-main);
  scroll-behavior: smooth;
  font-variant-numeric: tabular-nums;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  font-size: var(--font-base);
  line-height: var(--lh-base);
}

html {
  scroll-padding-top: 64px;
  overflow-x: hidden;
}

body {
  overflow-x: hidden;
  overscroll-behavior-y: contain;
  -webkit-overflow-scrolling: touch;
  max-width: 100vw;
}

::selection {
  background: var(--accent-medium);
  color: var(--text-primary);
}

img, svg {
  display: block;
  max-width: 100%;
}

button {
  font-family: inherit;
  cursor: pointer;
}

input, select, textarea {
  font-family: inherit;
}

/* Prevent flex/grid children from causing horizontal overflow */
.result-card,
.profile-card,
.activity-card,
.kpi-card,
.health-metric-card,
.metric-timeseries-card,
.stats-summary-card,
.fitness-age-card,
.factor-bars-card {
  min-width: 0;
  max-width: 100%;
  box-sizing: border-box;
}


/* ───────────────────────────────────────────────────────────────
   3. REUSABLE COMPONENTS
   ─────────────────────────────────────────────────────────────── */

/* Avatar gradient */
.avatar-gradient {
  background: var(--gradient-avatar);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 700;
  border-radius: 50%;
}

/* Modal overlay (generic) */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 10000;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 40px 16px;
  overflow-y: auto;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.modal-card {
  background: var(--bg-primary);
  color: var(--text-primary);
  border-radius: var(--radius-xl);
  max-width: 640px;
  width: 100%;
  box-shadow: var(--shadow-xl);
  border: 1px solid var(--border);
  overflow: hidden;
}

.modal-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px;
  border-bottom: 1px solid var(--border);
}

.modal-card-body {
  padding: 22px;
}

/* Stat tile */
.stat-tile {
  background: var(--bg-secondary);
  border-radius: var(--radius-sm);
  padding: 12px;
  text-align: center;
}
.stat-tile-label {
  font-size: var(--font-xs);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.stat-tile-value {
  font-size: var(--font-xl);
  font-weight: var(--weight-bold);
  margin-top: 4px;
}

/* Section label */
.section-label {
  font-size: var(--font-sm);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: var(--weight-semi);
  margin-bottom: 8px;
}

/* Activity row */
.activity-row {
  display: flex;
  gap: 10px;
  align-items: center;
  padding: 10px;
  background: var(--bg-secondary);
  border-radius: var(--radius-sm);
}
.activity-row-icon { font-size: 20px; }
.activity-row-meta { flex: 1; min-width: 0; }
.activity-row-title {
  font-weight: 600;
  font-size: var(--font-base);
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.activity-row-sub { font-size: var(--font-sm); color: var(--text-muted); }
.activity-row-stats { text-align: right; font-size: var(--font-sm); color: var(--text-secondary); }
.activity-row-stats-sub { color: var(--text-muted); }

/* Effort analysis */
.effort-analysis { margin-top: 8px; }
.effort-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
  gap: 12px;
}
.effort-stat { text-align: center; }
.effort-stat-label {
  font-size: var(--font-xs);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 4px;
}
.effort-stat-value { font-size: var(--font-xl); font-weight: var(--weight-bold); }
.effort-stat-desc { font-size: var(--font-xs); color: var(--text-muted); margin-top: 2px; }
.effort-bar-track {
  height: 4px;
  background: var(--bg-tertiary);
  border-radius: 2px;
  margin-top: 6px;
  overflow: hidden;
}
.effort-bar {
  height: 100%;
  border-radius: 2px;
  transition: width 0.6s var(--transition-smooth);
}
.hr-zone-sublabel {
  display: block;
  font-size: 9px;
  color: var(--text-muted);
  font-weight: 400;
}
.hr-zone-bpm {
  font-size: 9px;
  color: var(--text-muted);
  min-width: 60px;
  text-align: right;
}
.pace-analysis-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
  gap: 10px;
  margin-top: 8px;
}

/* User Profile Viewer */
.upv-hero { display: flex; gap: 18px; align-items: center; margin-bottom: 20px; }
.upv-avatar-ring {
  width: 90px; height: 90px; border-radius: 50%; padding: 3px; flex-shrink: 0;
  background: var(--brand-gradient);
}
.upv-avatar-ring .upv-avatar-img {
  width: 100%; height: 100%; border-radius: 50%; object-fit: cover;
  border: 2px solid var(--bg-primary);
}
.upv-avatar-ring .upv-avatar-fallback {
  width: 100%; height: 100%; font-size: 32px;
  border: 2px solid var(--bg-primary);
}
.upv-avatar-img { width: 84px; height: 84px; border-radius: 50%; object-fit: cover; border: 2px solid var(--border); }
.upv-avatar-fallback { width: 84px; height: 84px; font-size: 32px; }
.upv-hero-meta { flex: 1; min-width: 0; }
.upv-name { font-size: 22px; font-weight: var(--weight-bold); color: var(--text-primary); }
.upv-email { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
.upv-stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 18px; }
.upv-activities-list { display: flex; flex-direction: column; gap: 8px; }

/* UPV VO2max badge */
.upv-vo2max-badge {
  display: flex; align-items: center; gap: 10px; padding: 10px 14px; margin-bottom: 18px;
  background: var(--accent-light);
  border: 1px solid var(--accent-medium);
  border-radius: var(--radius-md);
}
.upv-vo2max-icon { font-size: 20px; }
.upv-vo2max-label { font-size: 12px; color: var(--text-muted); flex: 1; }
.upv-vo2max-value { font-size: 20px; font-weight: var(--weight-bold); color: var(--accent); }

/* UPV Races */
.upv-races-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  gap: 10px;
  margin-bottom: 18px;
}
.upv-race-card {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.upv-race-card-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px; }
.upv-race-emoji { font-size: 22px; }
.upv-race-prio {
  font-size: 11px; font-weight: 700; color: #fff; padding: 2px 7px; border-radius: 6px;
  line-height: 1.3; text-transform: uppercase; letter-spacing: 0.5px;
}
.upv-race-name { font-size: 14px; font-weight: var(--weight-bold); color: var(--text-primary); line-height: 1.3; }
.upv-race-detail { font-size: 12px; color: var(--text-muted); }
.upv-race-countdown { font-size: 12px; color: var(--accent); font-weight: 600; }
.upv-race-goal { font-size: 12px; color: var(--text-muted); }

/* UPV Personal bests */
.upv-pbs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
  gap: 10px;
  margin-bottom: 18px;
}
.upv-pb-card {
  text-align: center; padding: 12px 8px; border-radius: var(--radius-md);
  background: var(--accent-light);
  border: 1px solid var(--accent-medium);
}
.upv-pb-dist { font-size: 11px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
.upv-pb-time { font-size: 18px; font-weight: var(--weight-bold); color: var(--text-primary); font-variant-numeric: tabular-nums; }
.upv-pb-date { font-size: 11px; color: var(--text-muted); margin-top: 4px; }

/* UPV Medals */
.upv-medals-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
  gap: 10px;
  margin-bottom: 18px;
}
.upv-medal-card {
  text-align: center; padding: 12px 8px; border-radius: var(--radius-md);
  position: relative;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
}
.upv-medal-card.is-pr { border-color: var(--accent-medium); background: var(--accent-light); }
.upv-medal-emoji { font-size: 28px; margin-bottom: 4px; }
.upv-medal-name {
  font-size: 12px; font-weight: 600; color: var(--text-primary);
  line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}


