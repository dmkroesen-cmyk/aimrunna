.playbook-form-host .landing-actions { text-align: left; }


/* ───────────────────────────────────────────────────────────────
   7. ACCOUNT BAR (desktop top nav)
   ─────────────────────────────────────────────────────────────── */

.account-bar {
  display: none;
  align-items: center;
  gap: var(--space-sm);
  padding: 0 var(--space-lg);
  height: 56px;
  background: var(--bg-primary);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 1000;
  width: 100%;
}

.account-bar-left,
.account-bar-right {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.account-bar-left { flex: 1; min-width: 0; }
.account-bar-right { flex-shrink: 0; }

.nav-brand {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  text-decoration: none;
  flex-shrink: 0;
}

.brand-mark {
  width: 28px;
  height: 28px;
  border-radius: var(--radius-sm);
  background: var(--brand-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 800;
  font-size: 14px;
}

.brand-wordmark {
  font-weight: 800;
  font-size: 16px;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

.account-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  border-radius: var(--radius-full);
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  transition: all 0.15s ease;
  cursor: pointer;
  white-space: nowrap;
}

.account-btn:hover {
  background: var(--bg-secondary);
  border-color: var(--border-strong);
  color: var(--text-primary);
}

.account-btn svg {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}

.nav-cta-race {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  border-radius: var(--radius-full);
  background: var(--accent);
  color: #fff;
  font-weight: 700;
  font-size: var(--font-sm);
  border: none;
  cursor: pointer;
  transition: all 0.15s ease;
}

.nav-cta-race:hover {
  background: #C07A0D;
  transform: translateY(-1px);
}

.notif-bell-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  position: relative;
  transition: all 0.15s ease;
}

.notif-bell-btn:hover {
  background: var(--bg-secondary);
  color: var(--text-primary);
}

.notif-bell-btn svg {
  width: 18px;
  height: 18px;
}

.account-pill {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 4px 12px 4px 4px;
  border-radius: var(--radius-full);
  border: 1px solid var(--border);
  background: transparent;
  cursor: pointer;
  transition: all 0.15s ease;
}

.account-pill:hover {
  background: var(--bg-secondary);
}

.account-pill img {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  object-fit: cover;
}


/* ───────────────────────────────────────────────────────────────
   8. ACCOUNT PANE
   ─────────────────────────────────────────────────────────────── */

.account-pane {
  display: none;
}

.account-pane.is-active {
  display: block;
}


/* ───────────────────────────────────────────────────────────────
   9. AMBIENT — REMOVED
   ─────────────────────────────────────────────────────────────── */

.ambient,
.ambient-grid,
.ambient-noise,
.ambient-glow {
  display: none !important;
  opacity: 0 !important;
  pointer-events: none !important;
}

body.has-output .ambient-glow { opacity: 0 !important; }


/* ───────────────────────────────────────────────────────────────
   10. SITE SHELL & SCROLL STAGE
   ─────────────────────────────────────────────────────────────── */

.site-shell {
  width: 100%;
  min-height: 100vh;
  position: relative;
}

.scroll-stage {
  position: relative;
  min-height: 100vh;
}

.scroll-sticky {
  position: sticky;
  top: 0;
  z-index: 10;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.hero-layer {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  opacity: 0.6;
}

.photo-strip {
  display: flex;
  gap: var(--space-md);
  padding: var(--space-lg);
  flex-wrap: wrap;
  justify-content: center;
  max-width: 900px;
}

.photo-strip.alt {
  flex-direction: row-reverse;
}

.photo-card {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--bg-secondary);
  width: 180px;
  height: 240px;
  flex-shrink: 0;
}

.photo-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.3), transparent);
  z-index: 1;
}

.photo-card span {
  position: absolute;
  bottom: 12px;
  left: 12px;
  z-index: 2;
  color: #fff;
  font-weight: 600;
  font-size: var(--font-sm);
}

.photo-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.photo-card.tall { height: 300px; }
.photo-card.wide { width: 260px; height: 200px; }
.photo-card.square { width: 200px; height: 200px; }

.landing-layer {
  position: relative;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: var(--space-2xl) var(--space-md);
}

.landing-panel {
  width: 100%;
  max-width: 560px;
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  padding: var(--space-xl);
  box-shadow: var(--shadow-lg);
  border: 1px solid var(--border);
}


/* ───────────────────────────────────────────────────────────────
   11. PLAN FORM / INTAKE FORM
   ─────────────────────────────────────────────────────────────── */

.intake-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  max-width: 520px;
  margin: 0 auto;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-sm);
}

.quick-grid.plan-top-controls {
  grid-template-columns: 1fr 1fr 1fr;
}

.quick-grid-minimal {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-sm);
}

.field {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.field[hidden],
.field.is-hidden {
  display: none;
}

.field > span,
.field label span {
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  color: var(--text-secondary);
}

.field input,
.field select,
.field textarea {
  padding: 10px 14px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border-input);
  background: var(--bg-primary);
  color: var(--text-primary);
  font-size: var(--font-base);
  transition: border-color 0.15s ease, box-shadow 0.15s ease;
  outline: none;
  width: 100%;
}

.field input:focus,
.field select:focus,
.field textarea:focus,
.field input:focus-visible,
.field select:focus-visible,
.field textarea:focus-visible {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-light);
}

.field input:invalid:not(:placeholder-shown):not(:focus) {
  border-color: var(--danger);
}

.field input::placeholder {
  color: var(--text-muted);
}

.field.is-select {
  position: relative;
}

.field.is-select select {
  appearance: none;
  padding-right: 36px;
}

.field-checkbox {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) 0;
  cursor: pointer;
}

.field-checkbox input[type="checkbox"] {
  width: 18px;
  height: 18px;
  accent-color: var(--accent);
  cursor: pointer;
  flex-shrink: 0;
}

.field-checkbox .checkbox-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex: 1;
}

.field-checkbox.is-disabled {
  opacity: 0.5;
  pointer-events: none;
}

.field-checkbox.is-disabled .checkbox-row {
  opacity: 0.5;
}

.cycle-detail-group.is-disabled .field {
  opacity: 0.4;
  pointer-events: none;
}

.pb-entry-row {
  display: grid;
  grid-template-columns: 1fr 1fr auto;
  gap: var(--space-sm);
  align-items: end;
}

.landing-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-md);
  margin-top: var(--space-lg);
}

/* Tuning toggle */
.tuning-toggle-row {
  display: flex;
  gap: var(--space-xs);
  background: var(--bg-tertiary);
  border-radius: var(--radius-sm);
  padding: 3px;
}

.tuning-toggle-btn {
  flex: 1;
  padding: 8px 12px;
  border: none;
  border-radius: 6px;
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
  white-space: nowrap;
}

.tuning-toggle-btn:hover {
  background: rgba(0, 0, 0, 0.04);
  color: var(--text-primary);
}

.tuning-toggle-btn.is-active {
  background: var(--bg-primary);
  color: var(--text-primary);
  font-weight: var(--weight-semi);
  box-shadow: var(--shadow-sm);
}

.advanced-settings {
  border-top: 1px solid var(--border);
  padding-top: var(--space-md);
  margin-top: var(--space-md);
}

.tuning-panel-host {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.tuning-panel-host[hidden] {
  display: none;
}

.advanced-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-sm);
}

.tuning-category {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: var(--space-sm);
}

.tuning-category-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  cursor: pointer;
}

.tuning-category-head h5 {
  margin: 0;
  font-size: var(--font-base);
  font-weight: var(--weight-semi);
  color: var(--text-primary);
}

.tuning-fields {
  padding: 0 16px 16px;
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.tuning-fields > .field,
.tuning-fields > label.field,
.tuning-fields > .cycle-detail-group {
  margin-bottom: 0;
}

.tuning-fields > [id] { scroll-margin-top: 80px; }

.tuning-panel-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-md);
}

.tuning-panel-grid[hidden] {
  display: none;
}

.advanced-settings.is-quick-hidden {
  display: none;
}


/* ───────────────────────────────────────────────────────────────
   12. CTA BUTTONS
   ─────────────────────────────────────────────────────────────── */

.cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  padding: 14px 28px;
  border: none;
  border-radius: var(--radius-md);
  background: var(--accent);
  color: #fff;
  font-size: var(--font-base);
  font-weight: var(--weight-bold);
  cursor: pointer;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
  text-align: center;
}

.cta::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), transparent);
  opacity: 0;
  transition: opacity 0.2s ease;
}

.cta:hover {
  background: #C07A0D;
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(212, 133, 15, 0.25);
}

.cta:hover::after { opacity: 1; }

.cta:active {
  transform: translateY(0);
  box-shadow: none;
}

.cta-race {
  background: var(--accent);
  color: #fff;
  font-weight: 700;
  border-radius: var(--radius-full);
  padding: 12px 24px;
}

.cta-mini {
  padding: 8px 16px;
  font-size: var(--font-sm);
  border-radius: var(--radius-sm);
  background: var(--accent);
  color: #fff;
  border: none;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s ease;
}

.cta-mini:hover { background: #C07A0D; }

.cta-accept {
  background: var(--success);
  color: #fff;
}

.cta-accept:hover { background: #15803D; }

.cta-google {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 12px 20px;
  background: var(--bg-primary);
  border: 1px solid var(--border-strong);
  border-radius: var(--radius-sm);
  color: var(--text-primary);
  font-weight: 600;
  font-size: var(--font-base);
  cursor: pointer;
  transition: all 0.15s ease;
}

.cta-google:hover {
  background: var(--bg-secondary);
  border-color: var(--border-hover);
}


/* ───────────────────────────────────────────────────────────────
   13. GHOST BUTTONS
   ─────────────────────────────────────────────────────────────── */

.ghost {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
  white-space: nowrap;
}

.ghost:hover {
  background: var(--bg-secondary);
  border-color: var(--border-strong);
  color: var(--text-primary);
}

.ghost:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

.ghost:active {
  transform: scale(0.97);
}

.ghost:disabled {
  opacity: 0.4;
  pointer-events: none;
}

.ghost.small {
  padding: 5px 10px;
  font-size: 11px;
}

.ghost.icon-only {
  padding: 6px;
  width: 32px;
  height: 32px;
  justify-content: center;
}

.ghost.icon-only.is-active {
  background: var(--accent-light);
  border-color: var(--accent-medium);
  color: var(--accent);
}

.ghost.danger {
  color: var(--danger);
  border-color: rgba(220, 38, 38, 0.15);
}

.ghost.danger:hover {
  background: var(--danger-light);
  border-color: rgba(220, 38, 38, 0.25);
}

.ghost-mini {
  padding: 4px 8px;
  font-size: 11px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.15s ease;
}

.ghost-mini:hover {
  background: var(--bg-secondary);
  color: var(--text-primary);
}


/* ───────────────────────────────────────────────────────────────
   14. TAGS & MICRO LABELS
   ─────────────────────────────────────────────────────────────── */

.tag.subtle {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: var(--radius-full);
  background: var(--bg-tertiary);
  color: var(--text-secondary);
  font-size: 11px;
  font-weight: var(--weight-medium);
  letter-spacing: 0.02em;
}

.micro-label {
  font-size: 10px;
  font-weight: var(--weight-semi);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
}


/* ───────────────────────────────────────────────────────────────
   15. STAGE REVEAL
   ─────────────────────────────────────────────────────────────── */

.stage-reveal {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s ease, transform 0.5s var(--transition-smooth);
}

.stage-reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}


/* ───────────────────────────────────────────────────────────────
   16. EMPTY STATES
   ─────────────────────────────────────────────────────────────── */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-2xl) var(--space-md);
  text-align: center;
}

.empty-state-icon {
  font-size: 48px;
  margin-bottom: var(--space-md);
  opacity: 0.5;
}

.empty-state-title {
  font-size: var(--font-lg);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  margin-bottom: var(--space-xs);
}

.empty-state-desc {
  font-size: var(--font-base);
  color: var(--text-secondary);
  max-width: 300px;
  line-height: var(--lh-base);
}


/* ───────────────────────────────────────────────────────────────
   17. CONNECTION STATE
   ─────────────────────────────────────────────────────────────── */

.connection-state {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 99999;
  padding: 8px 16px;
  text-align: center;
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  background: var(--danger-light);
  color: var(--danger);
  border-bottom: 1px solid rgba(220, 38, 38, 0.15);
}


/* ───────────────────────────────────────────────────────────────
   18. CONTENT SHELL
   ─────────────────────────────────────────────────────────────── */

.content-shell {
  width: 100%;
  max-width: var(--container);
  margin: 0 auto;
  padding: var(--space-md);
  padding-bottom: calc(80px + env(safe-area-inset-bottom, 0px));
}

.surface {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}

.surface-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-md);
}

.surface-head h3 {
  margin: 0;
  font-size: var(--font-xl);
  font-weight: var(--weight-bold);
}

.result-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-md);
}

.result-title-row h4 {
  margin: 0;
  font-size: var(--font-lg);
  font-weight: var(--weight-bold);
}


/* ───────────────────────────────────────────────────────────────
   19. PROFILE VIEW TABS
   ─────────────────────────────────────────────────────────────── */

.profile-view-tabs {
  display: flex;
  gap: 2px;
  background: var(--bg-tertiary);
  border-radius: var(--radius-sm);
  padding: 3px;
  margin-bottom: var(--space-lg);
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.profile-view-tab {
  flex: 1;
  padding: 8px 16px;
  border: none;
  border-radius: 6px;
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
  white-space: nowrap;
  text-align: center;
}

.profile-view-tab:hover { color: var(--text-primary); }

.profile-view-tab.is-active {
  background: var(--bg-primary);
  color: var(--text-primary);
  font-weight: var(--weight-semi);
  box-shadow: var(--shadow-sm);
}


/* ───────────────────────────────────────────────────────────────
   20. ACCOUNT GRID & CARDS
   ─────────────────────────────────────────────────────────────── */

.account-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-md);
}

.account-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
}

.account-card .result-title-row h4 {
  font-size: var(--font-lg);
  font-weight: var(--weight-bold);
}


/* ───────────────────────────────────────────────────────────────
   21. PROFILE SETTINGS
   ─────────────────────────────────────────────────────────────── */

.profile-settings-rail-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  margin-bottom: var(--space-md);
}

.profile-settings-nav {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.profile-settings-nav-btn {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: 10px 14px;
  border: none;
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-base);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
  text-align: left;
  width: 100%;
}

.profile-settings-nav-btn:hover {
  background: var(--bg-secondary);
  color: var(--text-primary);
}

.profile-settings-nav-btn.is-active {
  background: var(--accent-light);
  color: var(--accent);
  font-weight: var(--weight-semi);
}

.profile-settings-nav-btn svg {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

.profile-settings-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  display: none;
}

.profile-settings-card.is-active {
  display: block;
}

/* Connector list */
.connector-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.connector-row {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-md);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  transition: all 0.15s ease;
}

.connector-row:hover {
  background: var(--bg-secondary);
  border-color: var(--border-strong);
}

.connector-brand {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex-shrink: 0;
}

.connector-brand img {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-sm);
}

.connector-brand-name {
  font-weight: var(--weight-semi);
  font-size: var(--font-base);
  color: var(--text-primary);
}

.connector-detail,
.connector-info {
  flex: 1;
  min-width: 0;
}

.connector-info strong {
  display: block;
  font-size: var(--font-base);
  font-weight: var(--weight-semi);
}

.connector-status-text {
  font-size: var(--font-sm);
  color: var(--text-muted);
}

.connector-badge {
  font-size: var(--font-xs);
  font-weight: 600;
  padding: 2px 8px;
  border-radius: var(--radius-full);
}

.connector-toggle {
  background: transparent;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 6px 12px;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.15s ease;
}

.connector-toggle:hover {
  color: var(--text-primary);
  border-color: var(--border-strong);
}

.connector-status-card {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: var(--space-md);
}

.connector-status-card.is-disabled { opacity: 0.5; }

.connector-status-meta {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.connector-athlete-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) 0;
}

.connector-athlete-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.connector-athlete-avatar.fallback {
  background: var(--gradient-avatar);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 700;
  font-size: 14px;
}

.connector-athlete-copy { flex: 1; min-width: 0; }
.connector-athlete-copy strong { font-size: var(--font-base); display: block; }
.connector-athlete-copy small { font-size: var(--font-sm); color: var(--text-muted); }


/* ───────────────────────────────────────────────────────────────
   22. CALENDAR
   ─────────────────────────────────────────────────────────────── */

.calendar-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.calendar-list::-webkit-scrollbar { width: 4px; }
.calendar-list::-webkit-scrollbar-thumb {
  background: var(--border-strong);
  border-radius: 4px;
}
.calendar-list::-webkit-scrollbar-track { background: transparent; }

.week-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.week-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) var(--space-lg);
  border-bottom: 1px solid var(--border);
}

.week-head h4 {
  margin: 0;
  font-size: var(--font-base);
  font-weight: var(--weight-bold);
}

.week-focus {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: var(--weight-medium);
}

.day-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 1px;
  background: var(--border);
}

.day-card {
  background: var(--bg-primary);
  padding: var(--space-sm);
  min-height: 80px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  position: relative;
}

.day-card .day-label {
  font-size: 11px;
  font-weight: var(--weight-semi);
  color: var(--text-muted);
  text-transform: uppercase;
}

.day-card .day-number {
  font-size: var(--font-lg);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
}

.day-card.is-today {
  background: var(--accent-light);
}

.day-card.is-today .day-number {
  color: var(--accent);
}

.day-card.is-rest {
  background: var(--bg-secondary);
}

.result-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: var(--space-md);
}

.result-calendar-card {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-bottom: var(--space-sm);
}

.plan-meta {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex-wrap: wrap;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-md);
}

.plan-mission-brief {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-bottom: var(--space-md);
  font-size: var(--font-base);
  color: var(--text-secondary);
  line-height: var(--lh-base);
}

.plan-overview-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}

.plan-overview-plot {
  width: 100%;
  height: 200px;
}

.threshold-track-card {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: var(--space-md);
}

.cal-view-btn {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
}

.cal-view-btn:hover { background: var(--bg-secondary); }

.cal-view-btn.is-active {
  background: var(--accent-light);
  border-color: var(--accent-medium);
  color: var(--accent);
}

.cal-week-map,
.cal-month-map {
  width: 100%;
  overflow: hidden;
}

.cal-week-bars {
  display: flex;
  gap: 2px;
  align-items: flex-end;
  height: 60px;
}

.cal-week-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-xs) 0;
}


/* ───────────────────────────────────────────────────────────────
   23. HEUTE (TODAY) SCREEN
   ─────────────────────────────────────────────────────────────── */

.heute-screen {
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
  padding: var(--space-md) 0;
  max-width: 600px;
  margin: 0 auto;
}

.heute-readiness {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  padding: var(--space-lg);
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
}

.heute-readiness-ring {
  position: relative;
  width: 120px;
  height: 120px;
  flex-shrink: 0;
}

.heute-ring-svg {
  width: 100%;
  height: 100%;
  transform: rotate(-90deg);
}

.heute-ring-track {
  fill: none;
  stroke: var(--bg-tertiary);
  stroke-width: 8;
  stroke-linecap: round;
}

.heute-ring-progress {
  fill: none;
  stroke: var(--success);
  stroke-width: 8;
  stroke-linecap: round;
  transition: stroke-dashoffset 1s var(--transition-smooth);
}

.heute-ring-score {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1;
}

.heute-readiness-info {
  flex: 1;
  min-width: 0;
}

.heute-readiness-label {
  font-size: var(--font-sm);
  font-weight: var(--weight-semi);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-muted);
  margin-bottom: 4px;
}

.heute-readiness-interp {
  font-size: var(--font-lg);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  line-height: 1.3;
}

.heute-phase-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  border-radius: var(--radius-full);
  background: var(--accent-light);
  color: var(--accent);
  font-size: var(--font-sm);
  font-weight: var(--weight-semi);
  margin-top: var(--space-sm);
}

.heute-phase-tag::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--accent);
}

/* Decision badge (v2) */
.heute-decision-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 14px;
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
  margin-top: var(--space-sm);
}

.heute-decision-hard {
  background: var(--danger-light);
  color: var(--danger);
}

.heute-decision-easy {
  background: var(--success-light);
  color: var(--success);
}

.heute-decision-rest {
  background: var(--bg-tertiary);
  color: var(--text-secondary);
}

.heute-decision-reasons {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-top: var(--space-sm);
}

.heute-reason-item {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.heute-reason-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* Session card */
.heute-session-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
}

.heute-session-card.no-plan .heute-session-structure,
.heute-session-card.no-plan .heute-session-why,
.heute-session-card.no-plan .heute-session-actions {
  display: none;
}

.heute-session-header {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.heute-session-sport-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

.heute-session-type {
  font-size: var(--font-sm);
  font-weight: var(--weight-semi);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-muted);
}

.heute-session-duration {
  margin-left: auto;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: var(--weight-medium);
}

.heute-session-title {
  font-size: var(--font-xl);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  margin-bottom: var(--space-md);
  line-height: 1.3;
}

.heute-session-structure {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding: var(--space-md);
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-md);
}

.heute-session-structure:empty { display: none; }

.heute-struct-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.heute-struct-marker {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--text-muted);
  flex-shrink: 0;
}

.heute-struct-zone {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-size: 11px;
  font-weight: var(--weight-semi);
}

.heute-struct-zone[data-zone="z1"] { color: var(--success); background: var(--success-light); }
.heute-struct-zone[data-zone="z2"] { color: var(--warning); background: var(--warning-light); }
.heute-struct-zone[data-zone="z3"] { color: var(--danger); background: var(--danger-light); }
.heute-struct-zone[data-zone="z4"] { color: #B91C1C; background: rgba(185, 28, 28, 0.08); }

.heute-session-why {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: var(--lh-base);
  padding: var(--space-sm) 0;
  border-top: 1px solid var(--border);
  margin-bottom: var(--space-md);
}

.heute-session-why:empty { display: none; }

.heute-session-actions {
  display: flex;
  gap: var(--space-sm);
}

.heute-btn-start {
  flex: 1;
  padding: 12px;
  border: none;
  border-radius: var(--radius-md);
  background: var(--accent);
  color: #fff;
  font-weight: var(--weight-bold);
  font-size: var(--font-base);
  cursor: pointer;
  transition: all 0.15s ease;
}

.heute-btn-start:hover { background: #C07A0D; }
.heute-btn-start:active { transform: scale(0.98); }

.heute-btn-adjust,
.heute-btn-skip {
  padding: 12px 16px;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  background: transparent;
  color: var(--text-secondary);
  font-weight: var(--weight-medium);
  font-size: var(--font-sm);
  cursor: pointer;
  transition: all 0.15s ease;
}

.heute-btn-adjust:hover,
.heute-btn-skip:hover {
  background: var(--bg-secondary);
  color: var(--text-primary);
}

.heute-btn-adjust:active,
.heute-btn-skip:active { transform: scale(0.97); }

.heute-tomorrow {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
}

.heute-tomorrow-label {
  font-size: var(--font-sm);
  font-weight: var(--weight-semi);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-muted);
  margin-bottom: var(--space-xs);
}

.heute-tomorrow-text {
  font-size: var(--font-base);
  color: var(--text-secondary);
  line-height: var(--lh-base);
}

.heute-context {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.heute-context-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.heute-ctx-label {
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  color: var(--text-secondary);
  width: 80px;
  flex-shrink: 0;
}

.heute-ctx-bar {
  flex: 1;
  height: 6px;
  background: var(--bg-tertiary);
  border-radius: 3px;
  overflow: hidden;
}

.heute-ctx-bar-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.6s var(--transition-smooth);
}

.heute-ctx-value {
  font-size: var(--font-sm);
  font-weight: var(--weight-semi);
  color: var(--text-primary);
  min-width: 40px;
  text-align: right;
  font-variant-numeric: tabular-nums;
}

/* Quick log */
.heute-quicklog {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.heute-quicklog-title {
  font-size: var(--font-base);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
}

.heute-quicklog-label {
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  color: var(--text-secondary);
  margin-bottom: var(--space-xs);
}

.heute-quicklog-scale {
  display: flex;
  gap: var(--space-xs);
}

.heute-srpe-btn {
  flex: 1;
  padding: 8px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
  text-align: center;
}

.heute-srpe-btn:hover { background: var(--bg-secondary); }

.heute-srpe-btn.is-active {
  background: var(--accent-light);
  border-color: var(--accent);
  color: var(--accent);
  font-weight: var(--weight-bold);
}

.heute-quicklog-feel-btns {
  display: flex;
  gap: var(--space-xs);
  flex-wrap: wrap;
}

.heute-feel-btn {
  padding: 6px 14px;
  border: 1px solid var(--border);
  border-radius: var(--radius-full);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
}

.heute-feel-btn:hover { background: var(--bg-secondary); }

.heute-feel-btn.is-active {
  background: var(--accent-light);
  border-color: var(--accent);
  color: var(--accent);
}

.heute-feel-btn[data-feel="tired"].is-active {
  background: var(--warning-light);
  border-color: var(--warning);
  color: var(--warning);
}

.heute-feel-btn[data-feel="sore"].is-active {
  background: var(--danger-light);
  border-color: var(--danger);
  color: var(--danger);
}

.heute-quicklog-save {
  padding: 12px;
  border: none;
  border-radius: var(--radius-md);
  background: var(--accent);
  color: #fff;
  font-weight: var(--weight-bold);
  font-size: var(--font-base);
  cursor: pointer;
  transition: all 0.15s ease;
  width: 100%;
}

.heute-quicklog-save:hover { background: #C07A0D; }
.heute-quicklog-save:active { transform: scale(0.98); }


/* ───────────────────────────────────────────────────────────────
   24. PUBLIC PROFILE
   ─────────────────────────────────────────────────────────────── */

.section-public-profile {
  max-width: 800px;
  margin: 0 auto;
  padding: var(--space-lg);
}

.pp-banner {
  height: 200px;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: linear-gradient(135deg, var(--bg-tertiary), var(--bg-secondary));
  margin-bottom: -40px;
  position: relative;
}

.pp-banner img { width: 100%; height: 100%; object-fit: cover; }

.pp-identity {
  display: flex;
  align-items: flex-end;
  gap: var(--space-md);
  padding: 0 var(--space-lg);
  margin-bottom: var(--space-lg);
  position: relative;
  z-index: 1;
}

.pp-avatar {
  width: 88px;
  height: 88px;
  border-radius: 50%;
  border: 4px solid var(--bg-primary);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--gradient-avatar);
  display: flex;
  align-items: center;
  justify-content: center;
}

.pp-avatar img { width: 100%; height: 100%; object-fit: cover; }

.pp-name {
  font-size: var(--font-2xl);
  font-weight: var(--weight-black);
  color: var(--text-primary);
  margin: 0;
}

.pp-meta {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: 2px;
}

.pp-hero-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
  gap: var(--space-md);
  padding: var(--space-lg);
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-md);
}

.pp-hero-cell { text-align: center; }

.pp-hero-cell .value {
  font-size: var(--font-2xl);
  font-weight: var(--weight-black);
  color: var(--text-primary);
  line-height: 1.1;
}

.pp-hero-cell .label {
  font-size: var(--font-xs);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-top: 4px;
}

.pp-dot-matrix { margin-bottom: var(--space-md); }

.pp-sport-bars {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.pp-form-value {
  font-size: var(--font-xl);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
}

.pp-trophy-host {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.pp-pr-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.pp-totals-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.pp-main-events { margin-bottom: var(--space-md); }

.pp-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-md);
}

.pp-section-head h3 {
  margin: 0;
  font-size: var(--font-lg);
  font-weight: var(--weight-bold);
}


/* ───────────────────────────────────────────────────────────────
   25. PERFORMANCE STATE DASHBOARD
   ─────────────────────────────────────────────────────────────── */

.perf-state-dashboard {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
}

.perf-state-arcs {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-lg);
  padding: var(--space-md) 0;
}

.perf-arc {
  position: relative;
  width: 120px;
  height: 120px;
  flex-shrink: 0;
}

.perf-arc-svg {
  width: 100%;
  height: 100%;
  transform: rotate(-90deg);
}

.perf-arc-track {
  fill: none;
  stroke: var(--bg-tertiary);
  stroke-width: 8;
  stroke-linecap: round;
}

.perf-arc-progress {
  fill: none;
  stroke-width: 8;
  stroke-linecap: round;
  transition: stroke-dashoffset 1s var(--transition-smooth);
}

.perf-arc-inner {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.perf-arc-value {
  font-size: var(--font-2xl);
  font-weight: var(--weight-black);
  color: var(--text-primary);
  line-height: 1;
}

.perf-arc-label {
  font-size: var(--font-xs);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-top: 4px;
}

.perf-state-interp {
  text-align: center;
  padding: var(--space-md) 0;
  font-size: var(--font-base);
  color: var(--text-secondary);
  line-height: var(--lh-base);
}

.perf-state-race {
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-top: var(--space-md);
}

.perf-state-thresholds {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}

.perf-thr-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-sm) 0;
  border-bottom: 1px solid var(--border);
  font-size: var(--font-sm);
}

.perf-thr-row:last-child { border-bottom: none; }


/* ───────────────────────────────────────────────────────────────
   26. PERFORMANCE GRAPH
   ─────────────────────────────────────────────────────────────── */

.perf-graph-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
}

.perf-graph-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-md);
}

.perf-graph-header h4 {
  margin: 0;
  font-size: var(--font-lg);
  font-weight: var(--weight-bold);
}

.perf-graph-canvas {
  width: 100%;
  height: 250px;
  position: relative;
}

.perf-graph-svg { width: 100%; height: 100%; }

.perf-graph-legend {
  display: flex;
  gap: var(--space-md);
  flex-wrap: wrap;
  margin-top: var(--space-md);
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.perf-graph-range-btn {
  padding: 4px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-full);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
}

.perf-graph-range-btn:hover { background: var(--bg-secondary); }

.perf-graph-range-btn.is-active {
  background: var(--accent-light);
  border-color: var(--accent);
  color: var(--accent);
}


/* ───────────────────────────────────────────────────────────────
   27. STATS / CHARTS
   ─────────────────────────────────────────────────────────────── */

.stats-sub-nav {
  display: flex;
  gap: var(--space-xs);
  margin-bottom: var(--space-lg);
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 2px;
}

.profile-view-statistics .stats-sub-nav { display: flex; }

.stats-sub-tab {
  padding: 8px 16px;
  border: 1px solid var(--border);
  border-radius: var(--radius-full);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
  white-space: nowrap;
}

.stats-sub-tab:hover {
  background: var(--bg-secondary);
  color: var(--text-primary);
}

.stats-sub-tab.is-active {
  background: var(--accent-light);
  border-color: var(--accent);
  color: var(--accent);
  font-weight: var(--weight-semi);
}

.stats-sub-card { display: none; }
.stats-sub-card.stats-sub-active { display: block; }

.stats-chart-wrap {
  width: 100%;
  position: relative;
  margin-bottom: var(--space-md);
}

.stats-chart-svg { width: 100%; height: auto; }

.stats-summary-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.stats-summary-item {
  text-align: center;
  padding: var(--space-md);
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
}

.stats-summary-item .value {
  font-size: var(--font-xl);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
}

.stats-summary-item .label {
  font-size: var(--font-xs);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-top: 2px;
}

.stats-period-tabs {
  display: flex;
  gap: 2px;
  background: var(--bg-tertiary);
  border-radius: var(--radius-sm);
  padding: 3px;
  margin-bottom: var(--space-md);
}

.stats-period-tab {
  flex: 1;
  padding: 6px 12px;
  border: none;
  border-radius: 6px;
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
  text-align: center;
}

.stats-period-tab:hover { color: var(--text-primary); }

.stats-period-tab.is-active {
  background: var(--bg-primary);
  color: var(--text-primary);
  font-weight: var(--weight-semi);
  box-shadow: var(--shadow-sm);
}

.stats-range-toggle {
  display: flex;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
}

.stats-range-btn {
  padding: 5px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-full);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
}

.stats-range-btn:hover { background: var(--bg-secondary); }

.stats-range-btn.is-active {
  background: var(--accent-light);
  border-color: var(--accent);
  color: var(--accent);
}

.stats-metric-btn {
  padding: 5px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-full);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  cursor: pointer;
  transition: all 0.15s ease;
}

.stats-metric-btn:hover { background: var(--bg-secondary); }
.stats-metric-btn.is-active {
  background: var(--accent-light);
  border-color: var(--accent);
  color: var(--accent);
}

.stats-toggle-group {
  display: flex;
  gap: 2px;
  background: var(--bg-tertiary);
  border-radius: var(--radius-sm);
  padding: 3px;
}

.stats-toggle-btn {
  padding: 6px 14px;
  border: none;
  border-radius: 6px;
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
}

.stats-toggle-btn:hover { color: var(--text-primary); }
.stats-toggle-btn.is-active {
  background: var(--bg-primary);
  color: var(--text-primary);
  box-shadow: var(--shadow-sm);
}

.stats-pill {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: var(--radius-full);
  background: var(--bg-tertiary);
  color: var(--text-secondary);
  font-size: 11px;
  font-weight: var(--weight-medium);
}

.stats-volume-svg,
.stats-donut-svg,
.stats-pace-svg {
  width: 100%;
  height: auto;
  display: block;
}

.chart-legend {
  display: flex;
  gap: var(--space-md);
  flex-wrap: wrap;
  margin-top: var(--space-sm);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.legend-swatch {
  width: 10px;
  height: 10px;
  border-radius: 3px;
  flex-shrink: 0;
}

.chart-explain {
  font-size: var(--font-sm);
  color: var(--text-muted);
  margin-top: var(--space-sm);
  line-height: var(--lh-base);
}


/* ───────────────────────────────────────────────────────────────
   28. DASHBOARD RINGS
   ─────────────────────────────────────────────────────────────── */

.dashboard-rings-card {
  grid-column: 1 / -1;
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: visible;
  padding: var(--space-lg);
}

.dashboard-rings-container {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding: var(--space-md) 0;
  position: relative;
}

.dashboard-ring {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.dashboard-ring-primary {
  width: 180px;
  height: 180px;
  z-index: 2;
}

.dashboard-ring-secondary {
  width: 130px;
  height: 130px;
  z-index: 1;
  margin: 0 -14px;
}

.ring-svg {
  width: 100%;
  height: 100%;
  transform: rotate(-90deg);
}

.ring-track {
  fill: none;
  stroke: var(--bg-tertiary);
  stroke-width: 7;
  stroke-linecap: round;
}

.ring-progress {
  fill: none;
  stroke-width: 7;
  stroke-linecap: round;
  stroke-dasharray: 553;
  stroke-dashoffset: 553;
  transition: stroke-dashoffset 1.6s var(--transition-smooth), stroke 0.4s ease;
}

.dashboard-ring-primary .ring-track { stroke-width: 9; }
.dashboard-ring-primary .ring-progress { stroke-width: 9; }

[data-ring-type="readiness"] .ring-progress { stroke: var(--metric-readiness); }
[data-ring-type="strain"] .ring-progress { stroke: var(--metric-strain); }
[data-ring-type="recovery"] .ring-progress { stroke: var(--metric-recovery); }
[data-ring-type="hrv"] .ring-progress { stroke: var(--metric-hrv); }
[data-ring-type="sleep"] .ring-progress { stroke: var(--metric-sleep); }
[data-ring-type="steps"] .ring-progress { stroke: var(--metric-steps); }
[data-ring-type="fitness-age"] .ring-progress { stroke: var(--metric-fitness-age); }
[data-ring-type="vo2max"] .ring-progress { stroke: var(--metric-vo2max); }

.ring-label {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  pointer-events: none;
}

.ring-value {
  font-weight: var(--weight-black);
  letter-spacing: -0.5px;
  line-height: 1;
  color: var(--text-primary);
}

.dashboard-ring-primary .ring-value { font-size: 32px; }
.dashboard-ring-secondary .ring-value { font-size: 22px; }

.ring-caption {
  font-size: var(--font-xs);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-top: 4px;
}

.dashboard-config-panel {
  padding: var(--space-md);
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  margin-top: var(--space-md);
}


/* ───────────────────────────────────────────────────────────────
   29. KPI CARDS
   ─────────────────────────────────────────────────────────────── */

.dashboard-kpi-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
}

.dashboard-kpi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-md);
}

.kpi-item {
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  text-align: center;
  transition: all 0.15s ease;
}

.kpi-item:hover { background: var(--bg-tertiary); }

.kpi-label {
  font-size: var(--font-xs);
  font-weight: var(--weight-semi);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 4px;
}

.kpi-value {
  font-size: var(--font-2xl);
  font-weight: var(--weight-black);
  color: var(--text-primary);
  line-height: 1.1;
}

.kpi-unit {
  font-size: var(--font-sm);
  color: var(--text-muted);
  font-weight: var(--weight-medium);
}

.kpi-item-clickable {
  cursor: pointer;
  position: relative;
}

.kpi-item-clickable::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: var(--radius-md);
  border: 2px solid transparent;
  transition: border-color 0.15s ease;
}

.kpi-item-clickable:hover::after { border-color: var(--accent-medium); }
.kpi-item-clickable:active { transform: scale(0.98); }
.kpi-item-clickable:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }


/* ───────────────────────────────────────────────────────────────
   30. KPI MODAL
   ─────────────────────────────────────────────────────────────── */

.kpi-modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 10001;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0;
}

.kpi-modal-backdrop[hidden] { display: none !important; }

.kpi-modal {
  background: var(--bg-primary);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  width: 100%;
  max-width: 500px;
  max-height: 85vh;
  overflow-y: auto;
  padding: var(--space-lg);
  box-shadow: var(--shadow-xl);
  border-top: 1px solid var(--border);
}

.kpi-modal-close {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: none;
  background: var(--bg-secondary);
  color: var(--text-secondary);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s ease;
}

.kpi-modal-close:hover { background: var(--bg-tertiary); color: var(--text-primary); }

.kpi-modal-header { margin-bottom: var(--space-md); position: relative; }

.kpi-modal-eyebrow {
  font-size: var(--font-xs);
  font-weight: var(--weight-semi);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  margin-bottom: 4px;
}

.kpi-modal-title {
  font-size: var(--font-xl);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
}

.kpi-modal-value-row {
  display: flex;
  align-items: baseline;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.kpi-modal-value {
  font-size: var(--font-3xl);
  font-weight: var(--weight-black);
  color: var(--text-primary);
  line-height: 1;
}

.kpi-modal-unit { font-size: var(--font-lg); color: var(--text-muted); }

.kpi-modal-rating {
  display: inline-flex;
  padding: 4px 12px;
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  font-weight: var(--weight-semi);
}

.kpi-modal-rating.rating-excellent { background: var(--success-light); color: var(--success); }
.kpi-modal-rating.rating-good { background: rgba(22, 163, 74, 0.06); color: rgba(22, 163, 74, 0.8); }
.kpi-modal-rating.rating-average { background: var(--warning-light); color: var(--warning); }
.kpi-modal-rating.rating-poor { background: var(--danger-light); color: var(--danger); }


/* ───────────────────────────────────────────────────────────────
   31. FITNESS AGE
   ─────────────────────────────────────────────────────────────── */

.fitness-age-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  overflow: hidden;
}

.fitness-age-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: var(--space-lg) 0;
}

.fitness-age-number-wrap { display: flex; align-items: baseline; gap: 4px; }

.fitness-age-label {
  font-size: var(--font-xs);
  font-weight: var(--weight-semi);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  margin-bottom: var(--space-sm);
}

.fitness-age-number {
  font-size: 64px;
  font-weight: var(--weight-black);
  color: var(--text-primary);
  line-height: 1;
  letter-spacing: -2px;
}

.fitness-age-unit { font-size: var(--font-lg); font-weight: var(--weight-semi); color: var(--text-muted); }

.fitness-age-delta { font-size: var(--font-sm); font-weight: var(--weight-bold); margin-top: var(--space-xs); }
.fitness-age-delta.positive { color: var(--success); }
.fitness-age-delta.negative { color: var(--danger); }
.fitness-age-delta.neutral { color: var(--text-muted); }

.fitness-age-chart-wrap { width: 100%; height: 120px; position: relative; margin: var(--space-md) 0; }
.fitness-age-chart-wrap canvas { width: 100%; height: 100%; }

.fitness-age-factors {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-sm);
}

.fitness-factor {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) 0;
}

.fitness-factor .label { font-size: var(--font-sm); color: var(--text-secondary); width: 100px; flex-shrink: 0; }

.factor-bar {
  flex: 1;
  height: 6px;
  background: var(--bg-tertiary);
  border-radius: 3px;
  overflow: hidden;
}

.factor-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.6s var(--transition-smooth);
}

.fitness-factor .value { font-size: var(--font-sm); font-weight: var(--weight-bold); min-width: 40px; text-align: right; }


/* ───────────────────────────────────────────────────────────────
   32. HEALTH CARDS
   ─────────────────────────────────────────────────────────────── */

.health-chart-container { width: 100%; height: 200px; position: relative; }

.health-metric-current {
  display: flex;
  align-items: baseline;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.health-metric-value {
  font-size: var(--font-2xl);
  font-weight: var(--weight-black);
  color: var(--text-primary);
}


/* ───────────────────────────────────────────────────────────────
   33. RACE PREDICTIONS
   ─────────────────────────────────────────────────────────────── */

.race-predictions-hero {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}

.predictions-vitals {
  display: flex;
  gap: var(--space-lg);
  margin-bottom: var(--space-md);
}

.predictions-dual-view {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-lg);
}

.predictions-column { min-width: 0; }

.predictions-column-label {
  font-size: var(--font-sm);
  font-weight: var(--weight-semi);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-muted);
  margin-bottom: var(--space-md);
  padding-bottom: var(--space-xs);
  border-bottom: 1px solid var(--border);
}

.predictions-current .predictions-column-label { color: var(--text-secondary); }
.predictions-raceday .predictions-column-label { color: var(--accent); }

.predictions-grid {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.prediction-cell {
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.prediction-cell span { font-size: var(--font-sm); color: var(--text-secondary); }

.prediction-cell strong {
  font-size: var(--font-xl);
  font-weight: var(--weight-black);
  color: var(--text-primary);
  font-variant-numeric: tabular-nums;
}

.predictions-raceday .prediction-cell strong { color: var(--accent); }

.predictions-raceday-note {
  font-size: var(--font-sm);
  color: var(--text-muted);
  margin-top: var(--space-sm);
}

.predictions-adaptive-status {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: var(--space-md);
  padding: var(--space-sm);
  background: var(--bg-secondary);
  border-radius: var(--radius-sm);
}


/* ───────────────────────────────────────────────────────────────
   34. ATHLETE IDENTITY CARD
   ─────────────────────────────────────────────────────────────── */

.athlete-id-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
}

.athlete-id-tagline {
  font-size: var(--font-lg);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  margin-bottom: var(--space-md);
  line-height: 1.3;
}

.athlete-id-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.athlete-id-stat { text-align: center; }

.athlete-id-stat-val {
  font-size: var(--font-xl);
  font-weight: var(--weight-black);
  color: var(--text-primary);
  line-height: 1.1;
}

.athlete-id-stat-label {
  font-size: var(--font-xs);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-top: 2px;
}

.athlete-id-badges {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
  margin-bottom: var(--space-md);
}

.athlete-id-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  border-radius: var(--radius-full);
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  color: var(--text-secondary);
}

.athlete-id-race-timeline {
  padding-top: var(--space-md);
  border-top: 1px solid var(--border);
}


/* ───────────────────────────────────────────────────────────────
   35. HARD RHYTHM GRID
   ─────────────────────────────────────────────────────────────── */

.hard-rhythm-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4px;
}

.hard-rhythm-grid .day {
  aspect-ratio: 1;
  border-radius: var(--radius-sm);
  background: var(--bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-xs);
  font-weight: var(--weight-semi);
  color: var(--text-muted);
}


/* ───────────────────────────────────────────────────────────────
   36. ZONE TABLES
   ─────────────────────────────────────────────────────────────── */

.zone-table-wrap {
  width: 100%;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.zone-table-wrap table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--font-sm);
}

.zone-table-wrap th {
  text-align: left;
  padding: 8px 12px;
  font-weight: var(--weight-semi);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-size: var(--font-xs);
  border-bottom: 1px solid var(--border-strong);
}

.zone-table-wrap td {
  padding: 8px 12px;
  border-bottom: 1px solid var(--border);
  color: var(--text-primary);
}


/* ───────────────────────────────────────────────────────────────
   37. SOCIAL FEED
   ─────────────────────────────────────────────────────────────── */

.social-feed-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}

.social-feed-filter {
  display: flex;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
  overflow-x: auto;
}

.social-feed-filter-btn {
  padding: 6px 14px;
  border: 1px solid var(--border);
  border-radius: var(--radius-full);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
  white-space: nowrap;
}

.social-feed-filter-btn:hover { background: var(--bg-secondary); }

.social-feed-filter-btn.is-active {
  background: var(--accent-light);
  border-color: var(--accent);
  color: var(--accent);
}

.social-feed-prop-btn {
  padding: 6px 14px;
  border: 1px solid var(--border);
  border-radius: var(--radius-full);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  cursor: pointer;
  transition: all 0.15s ease;
}

.social-feed-prop-btn:hover { background: var(--bg-secondary); }


/* ───────────────────────────────────────────────────────────────
   38. CREW
   ─────────────────────────────────────────────────────────────── */

.crew-layout {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: var(--space-lg);
  max-width: var(--container);
  margin: 0 auto;
}

.crew-feed-main { min-width: 0; }

.crew-feed-main .activity-feed-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.crew-sidebar {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.crew-sidebar-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
}

.crew-sidebar-card .result-title-row h4 { font-size: var(--font-base); font-weight: var(--weight-bold); }
.crew-sidebar-card .empty-copy { font-size: var(--font-sm); color: var(--text-muted); }

.crew-add-form {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}

.crew-add-form input {
  flex: 1;
  padding: 8px 12px;
  border: 1px solid var(--border-input);
  border-radius: var(--radius-sm);
  background: var(--bg-primary);
  color: var(--text-primary);
  font-size: var(--font-sm);
}

.crew-add-form button {
  padding: 8px 14px;
  border: none;
  border-radius: var(--radius-sm);
  background: var(--accent);
  color: #fff;
  font-weight: 600;
  font-size: var(--font-sm);
  cursor: pointer;
}

.crew-challenges-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
}

.crew-feed-card {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
}


/* ───────────────────────────────────────────────────────────────
   39. SESSION OVERLAY
   ─────────────────────────────────────────────────────────────── */

.session-overlay {
  position: fixed;
  inset: 0;
  z-index: 10000;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.session-overlay[hidden] { display: none; }

.session-overlay-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.session-modal-card {
  position: relative;
  z-index: 1;
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  max-width: 600px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  margin-top: 40px;
  box-shadow: var(--shadow-xl);
  border: 1px solid var(--border);
  padding: var(--space-lg);
}


/* ───────────────────────────────────────────────────────────────
   40. ACCOUNT MODAL
   ─────────────────────────────────────────────────────────────── */

.account-modal {
  position: fixed;
  inset: 0;
  z-index: 10002;
  display: flex;
  align-items: center;
  justify-content: center;
}

.account-modal[hidden] { display: none; }

.account-modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.account-modal-card {
  position: relative;
  z-index: 1;
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  max-width: 480px;
  width: 90%;
  padding: var(--space-xl);
  box-shadow: var(--shadow-xl);
  border: 1px solid var(--border);
}

.account-modal-card > .result-title-row { margin-bottom: var(--space-md); }


/* ───────────────────────────────────────────────────────────────
   41. MEDAL MODAL
   ─────────────────────────────────────────────────────────────── */

.medal-modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 10003;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
}

.medal-modal-backdrop[hidden] { display: none; }

.medal-modal {
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  max-width: 480px;
  width: 90%;
  padding: var(--space-xl);
  box-shadow: var(--shadow-xl);
  border: 1px solid var(--border);
  text-align: center;
}

.medal-detect-backdrop {
  position: fixed;
  inset: 0;
  z-index: 10004;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
}

.medal-detect-backdrop[hidden] { display: none; }


/* ───────────────────────────────────────────────────────────────
   42. TARGET MODAL
   ─────────────────────────────────────────────────────────────── */

.target-modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 10003;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
}

.target-modal-backdrop[hidden] { display: none; }

.target-modal {
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  max-width: 520px;
  width: 90%;
  padding: var(--space-xl);
  box-shadow: var(--shadow-xl);
  border: 1px solid var(--border);
}


/* ───────────────────────────────────────────────────────────────
   43. COOKIE CONSENT
   ─────────────────────────────────────────────────────────────── */

.cookie-consent-banner {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99999;
  background: var(--bg-primary);
  border-top: 1px solid var(--border);
  padding: var(--space-lg);
  box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  flex-wrap: wrap;
}

.cookie-consent-banner[hidden] { display: none; }

.cookie-consent-banner p {
  margin: 0;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  flex: 1;
  min-width: 200px;
}


/* ───────────────────────────────────────────────────────────────
   44. LOGIN SUCCESS OVERLAY
   ─────────────────────────────────────────────────────────────── */

.login-success-overlay {
  position: fixed;
  inset: 0;
  z-index: 100000;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 1;
  transition: opacity 0.4s ease;
}

.login-success-overlay[hidden] { display: none; }

.login-success-overlay.is-fading {
  opacity: 0;
  pointer-events: none;
}

.login-success-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-lg);
}

.login-success-ring { width: 120px; height: 120px; position: relative; }
.login-success-ring svg { width: 100%; height: 100%; }

.login-success-icon {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  color: var(--success);
}

.login-success-brand {
  font-size: var(--font-2xl);
  font-weight: var(--weight-black);
  color: var(--text-primary);
}

.login-success-msg {
  font-size: var(--font-lg);
  color: var(--text-secondary);
}


/* ───────────────────────────────────────────────────────────────
   45. ACCOUNT & ACTIVITY FORMS
   ─────────────────────────────────────────────────────────────── */

.account-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.account-form .field input,
.account-form .field select,
.account-form .field textarea {
  padding: 10px 14px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border-input);
  background: var(--bg-primary);
  color: var(--text-primary);
  font-size: var(--font-base);
}

.activity-post-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding: var(--space-lg);
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
}

.activity-type-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 14px;
  border-radius: var(--radius-full);
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
}

.activity-type-chip:hover { background: var(--bg-secondary); }

.activity-type-chip.is-active {
  background: var(--accent-light);
  border-color: var(--accent);
  color: var(--accent);
}

.activity-meta-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: var(--space-sm);
}


/* ───────────────────────────────────────────────────────────────
   46. ATHLETES DRAWER
   ─────────────────────────────────────────────────────────────── */

.athletes-drawer-backdrop {
  position: fixed;
  inset: 0;
  z-index: 9998;
  background: rgba(0, 0, 0, 0.25);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
}

body.athletes-drawer-open .athletes-drawer-backdrop {
  opacity: 1;
  pointer-events: auto;
}

.athletes-drawer {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: 320px;
  max-width: 85vw;
  z-index: 9999;
  background: var(--bg-primary);
  border-right: 1px solid var(--border);
  box-shadow: var(--shadow-xl);
  transform: translateX(-100%);
  transition: transform 0.3s var(--transition-smooth);
  overflow-y: auto;
  padding: var(--space-lg);
}

body.athletes-drawer-open .athletes-drawer {
  transform: translateX(0);
}


/* ───────────────────────────────────────────────────────────────
   47. NOTIFICATIONS
   ─────────────────────────────────────────────────────────────── */

.notif-dropdown {
  position: absolute;
  top: 100%;
  right: 0;
  width: 360px;
  max-height: 440px;
  overflow-y: auto;
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  z-index: 10000;
  display: none;
}

.notif-dropdown.is-open { display: block; }

.notif-list {
  display: flex;
  flex-direction: column;
}

.notif-list .notif-item {
  padding: var(--space-md);
  border-bottom: 1px solid var(--border);
  display: flex;
  gap: var(--space-sm);
  transition: background 0.1s ease;
}

.notif-list .notif-item:hover { background: var(--bg-secondary); }
.notif-list .notif-item:last-child { border-bottom: none; }


/* ───────────────────────────────────────────────────────────────
   48. PR FLIP CARD
   ─────────────────────────────────────────────────────────────── */

.pr-flip-card { perspective: 800px; cursor: pointer; }
.pp-pr-vault.pr-flip-card { perspective: 800px; }

.pr-flip-inner {
  position: relative;
  width: 100%;
  transition: transform 0.6s ease;
  transform-style: preserve-3d;
}

.pr-flip-card.is-flipped .pr-flip-inner { transform: rotateY(180deg); }

.pr-flip-face {
  backface-visibility: hidden;
  border-radius: var(--radius-md);
  padding: var(--space-md);
  background: var(--bg-secondary);
  border: 1px solid var(--border);
}

.pp-pr-vault.pr-flip-card .pr-flip-face { background: var(--bg-secondary); }

.pr-flip-front { position: relative; }

.pr-flip-back {
  position: absolute;
  inset: 0;
  transform: rotateY(180deg);
  overflow-y: auto;
}

.pr-flip-card.is-flipped .pr-flip-front { visibility: hidden; }
.pr-flip-card.is-flipped .pr-flip-back { visibility: visible; }

.pr-flip-btn {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  border: 1px solid var(--border);
  border-radius: var(--radius-full);
  background: transparent;
  color: var(--text-muted);
  font-size: 11px;
  cursor: pointer;
  transition: all 0.15s ease;
}

.pr-flip-btn:hover { background: var(--bg-secondary); color: var(--text-primary); }


/* ───────────────────────────────────────────────────────────────
   49. SITE FOOTER
   ─────────────────────────────────────────────────────────────── */

.site-footer {
  padding: var(--space-2xl) var(--space-md);
  border-top: 1px solid var(--border);
  text-align: center;
  color: var(--text-muted);
  font-size: var(--font-sm);
}

.footer-lang {
  display: flex;
  gap: var(--space-xs);
  justify-content: center;
  margin-top: var(--space-md);
}

.lang-btn {
  padding: 4px 10px;
  border: 1px solid var(--border);
  border-radius: var(--radius-full);
  background: transparent;
  color: var(--text-muted);
  font-size: var(--font-sm);
  cursor: pointer;
  transition: all 0.15s ease;
}

.lang-btn:hover { background: var(--bg-secondary); color: var(--text-primary); }

.lang-btn.is-active {
  background: var(--accent-light);
  border-color: var(--accent);
  color: var(--accent);
}


/* ───────────────────────────────────────────────────────────────
   50. LEGAL
   ─────────────────────────────────────────────────────────────── */

.legal-layout {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: var(--space-lg);
  max-width: 960px;
  margin: 0 auto;
  padding: var(--space-lg);
}

.legal-nav {
  display: flex;
  flex-direction: column;
  gap: 2px;
  position: sticky;
  top: 80px;
}

.legal-nav-btn {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: 10px 14px;
  border: none;
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--font-base);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all 0.15s ease;
  text-align: left;
}

.legal-nav-btn:hover { background: var(--bg-secondary); color: var(--text-primary); }

.legal-nav-btn.is-active {
  background: var(--accent-light);
  color: var(--accent);
  font-weight: var(--weight-semi);
}


/* ───────────────────────────────────────────────────────────────
   51. GLOSSARY
   ─────────────────────────────────────────────────────────────── */

.glossary-modal-card {
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  max-width: 640px;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
  padding: var(--space-lg);
  box-shadow: var(--shadow-xl);
  border: 1px solid var(--border);
}

.glossary-toolbar {
  display: flex;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
  padding-bottom: var(--space-md);
  border-bottom: 1px solid var(--border);
}

.glossary-toolbar input {
  flex: 1;
  padding: 8px 14px;
  border: 1px solid var(--border-input);
  border-radius: var(--radius-sm);
  background: var(--bg-primary);
  color: var(--text-primary);
  font-size: var(--font-base);
}

.glossary-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.glossary-list dt {
  font-weight: var(--weight-bold);
  font-size: var(--font-base);
  color: var(--text-primary);
  margin-top: var(--space-sm);
}

.glossary-list dd {
  margin: 0;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: var(--lh-base);
}


/* ───────────────────────────────────────────────────────────────
   52. ACCOUNT INLINE ACTIONS
   ─────────────────────────────────────────────────────────────── */

.account-inline-actions {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

.account-inline-actions .ghost { font-size: var(--font-sm); }


/* ───────────────────────────────────────────────────────────────
   53. TAB BAR (mobile bottom navigation)
   ─────────────────────────────────────────────────────────────── */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  display: none;
  align-items: flex-end;
  justify-content: space-around;
  height: 64px;
  padding-bottom: env(safe-area-inset-bottom, 0px);
  background: var(--bg-primary);
  border-top: 1px solid var(--border);
}

body.has-tab-bar .tab-bar { display: flex; }

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  height: 100%;
  padding: 8px 0 6px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--text-muted);
  transition: color 0.2s ease;
  -webkit-tap-highlight-color: transparent;
  position: relative;
}

.tab-bar-item.is-active { color: var(--accent); }
.tab-bar-item:active { transform: scale(0.92); }

.tab-bar-icon {
  width: 22px;
  height: 22px;
  flex-shrink: 0;
}

.tab-bar-icon svg { width: 100%; height: 100%; }

.tab-bar-label {
  font: 500 10px/1 var(--font-main);
  letter-spacing: 0.02em;
}

.tab-bar-fab {
  position: relative;
  margin-top: -16px;
}

.tab-bar-fab-ring {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: var(--brand-gradient);
  box-shadow: 0 4px 20px rgba(212, 133, 15, 0.30), 0 0 0 3px rgba(212, 133, 15, 0.10);
  transition: transform 0.2s var(--transition-smooth), box-shadow 0.2s ease;
}

.tab-bar-fab-ring svg {
  stroke: #fff;
  width: 24px;
  height: 24px;
}

.tab-bar-fab:active .tab-bar-fab-ring {
  transform: scale(0.9);
  box-shadow: 0 2px 10px rgba(212, 133, 15, 0.40), 0 0 0 2px rgba(212, 133, 15, 0.12);
}

.tab-bar-fab .tab-bar-label {
  font-weight: 700;
  color: var(--accent);
  margin-top: 2px;
}

.tab-bar-avatar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
}

.tab-bar-avatar.has-image {
  border-radius: 50%;
  border: 2px solid var(--accent);
  overflow: hidden;
}

.tab-bar-avatar.has-image svg { display: none; }

.tab-bar-avatar.has-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}

.tab-bar-item.is-active::before {
  content: '';
  position: absolute;
  top: 4px;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--accent);
}

.tab-bar-fab.is-active::before { display: none; }


/* ───────────────────────────────────────────────────────────────
   54. SCROLLBAR
   ─────────────────────────────────────────────────────────────── */

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: rgba(0, 0, 0, 0.2); }


/* ═══════════════════════════════════════════════════════════════
   RESPONSIVE — DESKTOP (769px+)
   ═══════════════════════════════════════════════════════════════ */

@media (min-width: 769px) {
  .account-bar { display: flex; }
  .tab-bar { display: none !important; }
  body.has-tab-bar .tab-bar { display: none !important; }

  .content-shell {
    padding: var(--space-lg) var(--space-xl);
    padding-bottom: var(--space-2xl);
  }

  .scroll-stage { min-height: 100vh; }
  .scroll-sticky { min-height: 100vh; }
  .landing-layer { min-height: 100vh; }

  .landing-panel {
    max-width: 560px;
    padding: var(--space-2xl);
  }

  .quick-grid { grid-template-columns: 1fr 1fr 1fr; }
  .quick-grid.plan-top-controls { grid-template-columns: 1fr 1fr 1fr; }
  .tuning-panel-grid { grid-template-columns: 1fr 1fr; }
  .tuning-category { break-inside: avoid; }

  .photo-strip {
    flex-wrap: nowrap;
    gap: var(--space-lg);
  }

  .photo-card.square { width: 220px; height: 220px; }
  .dashboard-kpi-grid { grid-template-columns: repeat(4, 1fr); }

  .crew-layout { grid-template-columns: 1fr 320px; }
  .legal-layout { grid-template-columns: 240px 1fr; }
  .glossary-modal-card { max-width: 640px; }

  .kpi-modal-backdrop { align-items: center; padding: var(--space-lg); }
  .kpi-modal {
    border-radius: var(--radius-xl);
    border-bottom: 1px solid var(--border);
    max-height: 86vh;
  }

  .predictions-dual-view { grid-template-columns: 1fr 1fr; }

  .profile-settings-rail-card { position: sticky; top: 72px; }
  .heute-screen { max-width: 640px; }
  .account-grid { grid-template-columns: 1fr 1fr; }
}


/* ═══════════════════════════════════════════════════════════════
   RESPONSIVE — LARGE DESKTOP (1100px+)
   ═══════════════════════════════════════════════════════════════ */

@media (min-width: 1100px) {
  .quick-grid,
  .quick-grid-minimal { grid-template-columns: 1fr 1fr 1fr; }
  .dashboard-kpi-grid { grid-template-columns: repeat(5, 1fr); }
}


/* ═══════════════════════════════════════════════════════════════
   RESPONSIVE — MOBILE (<769px)
   ═══════════════════════════════════════════════════════════════ */

@media (max-width: 768px) {
  .account-bar { display: none !important; }
  body.has-tab-bar .tab-bar { display: flex; }

  .content-shell {
    padding: var(--space-md);
    padding-bottom: calc(80px + env(safe-area-inset-bottom, 0px));
  }

  body.app-view-profile .content-shell,
  body.app-view-crew .content-shell { padding-top: var(--space-md); }

  .scroll-sticky { min-height: auto; }

  .landing-layer {
    min-height: auto;
    padding: var(--space-lg) var(--space-md);
  }

  .landing-panel {
    padding: var(--space-lg);
    border-radius: var(--radius-lg);
  }

  .landing-actions {
    flex-direction: column;
    width: 100%;
  }

  .landing-actions .cta { width: 100%; }

  .photo-strip,
  .photo-strip.alt { display: none; }

  .quick-grid { grid-template-columns: 1fr 1fr; }
  .quick-grid.plan-top-controls { grid-template-columns: 1fr 1fr; }

  .tuning-toggle-row { overflow-x: auto; }
  .tuning-panel-grid { grid-template-columns: 1fr; }

  #tuning-panel-performance .field,
  .tuning-fields > .field { margin-bottom: 0; }

  .predictions-dual-view {
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .prediction-cell strong { font-size: var(--font-lg); }

  .dashboard-kpi-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm);
  }

  .kpi-item { padding: var(--space-sm); }

  .crew-layout { grid-template-columns: 1fr; }
  .crew-feed-main { order: 1; }
  .crew-sidebar { order: 2; }

  .legal-layout { grid-template-columns: 1fr; }

  .legal-nav {
    position: static;
    flex-direction: row;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .legal-nav-btn { white-space: nowrap; }

  .glossary-modal-card {
    max-width: 100%;
    border-radius: var(--radius-lg);
  }

  .site-footer {
    padding-bottom: calc(80px + env(safe-area-inset-bottom, 0px));
  }

  .surface-head .micro-label { font-size: 9px; }

  .ghost,
  .ghost.small { padding: 6px 10px; font-size: 11px; }

  .field input,
  .field select,
  .field textarea { font-size: 16px; }

  .field label span,
  .field > span { font-size: 11px; }

  .cta { font-size: var(--font-sm); padding: 12px 20px; }

  .calendar-list { gap: var(--space-sm); }

  .day-grid {
    grid-template-columns: repeat(7, 1fr);
    gap: 0;
  }

  .day-card { padding: 4px; min-height: 60px; }

  .stats-sub-nav { flex-wrap: wrap; justify-content: center; }

  .profile-settings-rail-card { margin-bottom: var(--space-md); }

  .profile-settings-nav {
    flex-direction: row;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    gap: 4px;
  }

  .profile-settings-nav-btn {
    white-space: nowrap;
    flex-shrink: 0;
    padding: 8px 12px;
    font-size: var(--font-sm);
  }

  .profile-settings-card { padding: var(--space-md); }

  .account-inline-actions .ghost { padding: 5px 8px; font-size: 11px; }

  .perf-state-arcs { gap: var(--space-sm); }
  .perf-arc { width: 100px; height: 100px; }
  .fitness-age-number { font-size: 48px; }
}


/* ═══════════════════════════════════════════════════════════════
   RESPONSIVE — SMALL MOBILE (<480px)
   ═══════════════════════════════════════════════════════════════ */

@media (max-width: 480px) {
  .landing-panel {
    padding: var(--space-md);
    border-radius: var(--radius-md);
  }

  .dashboard-kpi-grid { grid-template-columns: repeat(2, 1fr); }
  .kpi-item { padding: var(--space-sm); }
  .kpi-value { font-size: var(--font-xl); }

  .crew-sidebar { gap: var(--space-sm); }

  .perf-state-arcs { flex-direction: column; align-items: center; }
  .athlete-id-stats { grid-template-columns: repeat(2, 1fr); }
  .pp-hero-stats { grid-template-columns: repeat(2, 1fr); }
}


/* ═══════════════════════════════════════════════════════════════
   HOVER-CAPABLE DEVICES
   ═══════════════════════════════════════════════════════════════ */

@media (hover: hover) and (pointer: fine) {
  .day-card:hover { background: var(--bg-secondary); }
  .day-card.is-today:hover { background: var(--accent-light); }
  .tab-bar-item:hover { color: var(--text-secondary); }
  .tab-bar-item.is-active:hover { color: var(--accent); }
  .result-card:hover { border-color: var(--border-strong); }
  .week-card:hover { border-color: var(--border-strong); }
  .connector-row:hover { background: var(--bg-secondary); }
}


/* ═══════════════════════════════════════════════════════════════
   REDUCED MOTION
   ═══════════════════════════════════════════════════════════════ */

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }

  .landing-panel,
  .stage-reveal,
  .content-shell {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
}


/* ═══════════════════════════════════════════════════════════════
   ANIMATIONS
   ═══════════════════════════════════════════════════════════════ */

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes pulseRing {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.05); }
}

@media (prefers-reduced-motion: no-preference) {
  .landing-panel { animation: fadeInUp 0.6s var(--transition-smooth) both; }
  .content-shell { animation: fadeIn 0.4s ease both; }
}


/* ═══════════════════════════════════════════════════════════════
   SAFE AREA INSETS
   ═══════════════════════════════════════════════════════════════ */

@supports (padding: env(safe-area-inset-bottom)) {
  .tab-bar {
    padding-bottom: env(safe-area-inset-bottom, 0px);
    height: calc(64px + env(safe-area-inset-bottom, 0px));
  }

  .content-shell {
    padding-bottom: calc(80px + env(safe-area-inset-bottom, 0px));
  }

  .cookie-consent-banner {
    padding-bottom: calc(var(--space-lg) + env(safe-area-inset-bottom, 0px));
  }
}


/* ═══════════════════════════════════════════════════════════════
   PRINT
   ═══════════════════════════════════════════════════════════════ */

@media print {
  .tab-bar,
  .account-bar,
  .cookie-consent-banner,
  .site-footer,
  .ambient,
  .ambient-grid,
  .ambient-noise,
  .ambient-glow { display: none !important; }

  body { background: #fff; color: #000; }
  .content-shell { padding: 0; max-width: 100%; }
}
